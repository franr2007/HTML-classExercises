{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "foto":        { "type": "string" },
        "nombre":      { "type": "string" },
        "descripcion": { "type": "string" },
        "precio":      { "type": "number" },
        "ventajas": {
            "type": "object",
            "properties": {
              "descripcion": { "type": "string" },
              "incluye": { "type": "string" },
              "habitaciones": { "type": "string" },
              "restaurante": { "type": "string" },
              "actividades": { "type": "string" },
              "situado": { "type": "string" },
              "incluye_precio": { "type": "string" },
              "noIncluye": { "type": "string" }
            }
        }
    }
}